{
  "name": "voltras-mcp",
  "version": "0.4.0",
  "description": "MCP server exposing Voltra device control, session recording, history, and analytics as tools and resources for Claude.",
  "type": "module",
  "bin": {
    "voltras-mcp": "./dist/bin.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:dashboard": "vite build --config src/dashboard/spa/vite.config.ts",
    "start": "node ./dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit && npm run typecheck:spa",
    "typecheck:spa": "tsc -p src/dashboard/spa/tsconfig.json",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,mjs,cjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,mjs,cjs,json}\"",
    "voice:setup": "scripts/setup-voice.sh",
    "voice:clean": "scripts/clean-voice.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@voltras/node-sdk": "^0.11.0",
    "@voltras/workout-analytics": "^1.5.0",
    "node-record-lpcm16": "^1.0.1",
    "nodejs-whisper": "^0.3.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@react-native/assets-registry": "^0.83.10",
    "@titan-design/react-ui": "^0.6.0",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.23.0",
    "nativewind": "^4.2.6",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native-body-highlighter": "^3.2.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.19.13",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "voltras",
    "voltra",
    "fitness",
    "ble"
  ],
  "license": "UNLICENSED"
}
