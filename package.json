{
  "name": "voltras-mcp",
  "version": "0.4.0",
  "description": "MCP server exposing Voltra device control, session recording, history, and analytics as tools and resources for Claude.",
  "type": "module",
  "bin": {
    "voltras-mcp": "./dist/bin.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,mjs,cjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,mjs,cjs,json}\"",
    "voice:setup": "scripts/setup-voice.sh",
    "voice:clean": "scripts/clean-voice.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@voltras/node-sdk": "^0.10.1",
    "@voltras/workout-analytics": "^1.2.0",
    "node-record-lpcm16": "^1.0.1",
    "nodejs-whisper": "^0.3.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "voltras",
    "voltra",
    "fitness",
    "ble"
  ],
  "license": "UNLICENSED"
}
